---
import { useTranslations, getLangFromUrl, type Lang } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---

<section id="contact" class="contact">
  <div class="container">
    <div class="cta-card">
      <h2 class="cta-title">{t('contact.title')}</h2>
      <p class="cta-desc">{t('contact.desc')}</p>
      <a href="https://become.nuros.org/" class="cta-btn" target="_blank" rel="noopener">
        {t('contact.form')}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .contact { padding: var(--spacing-xl) 0; }

  .cta-card {
    text-align: center;
    padding: var(--spacing-xl) var(--spacing-lg);
    border: 1px solid rgba(138,180,232,0.2);
    border-radius: calc(var(--border-radius) * 2);
    background: linear-gradient(135deg, rgba(26,91,156,0.15) 0%, rgba(26,26,26,0) 100%);
    max-width: 560px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: var(--spacing-sm);
  }

  .cta-desc {
    font-size: 1rem;
    color: rgba(224,224,224,0.65);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    background: var(--primary-color);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: var(--border-radius);
    transition: background .2s, transform .2s;
  }
  .cta-btn:hover {
    background: var(--primary-hover, #1d6db5);
    transform: translateY(-2px);
    opacity: 1;
    color: #fff;
  }
</style>
